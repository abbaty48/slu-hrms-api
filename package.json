{
  "name": "sluk-hrms-api",
  "version": "1.0.0",
  "description": "Sule lamido university Human Resource Management System API.",
  "main": "app.ts",
  "author": "",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file=.env --watch --expose-gc app.ts",
    "start": "node --env-file=.env app.ts",
    "start:gc": "node --expose-gc app.ts",
    "start:inspect": "node --inspect app.ts",
    "start:prod": "NODE_ENV=production node --expose-gc app.ts"
  },
  "keywords": [
    "fastify",
    "api",
    "postgresql",
    "prisma"
  ],
  "imports": {
    "#configs/*": "./configs/*",
    "#schemas/*": "./schemas/*",
    "#plugins/*": "./plugins/*",
    "#routes/*": "./routes/*",
    "#utils/*": "./utils/*"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/mongodb": "^10.0.0",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/reply-from": "^12.6.1",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@immobiliarelabs/fastify-metrics": "^7.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.0",
    "lru-cache": "^11.2.7",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  }
}
