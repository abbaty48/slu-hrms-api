// ============================================================
// PRISMA SCHEMA — HR Management System
// Aligned 1-to-1 with schema_seed.sql (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS  (@@map binds to SQL CREATE TYPE names)
// ============================================================

enum UserRole {
  admin
  staff
  manager

  @@map("user_role")
}

enum StaffStatus {
  Employed
  On_Leave       @map("On Leave")
  Retired
  Terminated
  Resigned
  Contract_Ended @map("Contract Ended")

  @@map("staff_status")
}

enum Gender {
  Male
  Female

  @@map("gender_type")
}

enum Cadre {
  Teaching
  Technical
  Non_Teaching   @map("Non-Teaching")
  Administrative

  @@map("cadre_type")
}

enum StaffCategory {
  Senior
  Junior

  @@map("staff_category")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@map("leave_status")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
  WEEKEND
  HOLIDAY

  @@map("att_status")
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID

  @@map("payroll_status")
}

enum NotificationType {
  leave_approved
  leave_rejected
  leave_pending
  payroll
  contract
  system
  profile
  attendance
  general

  @@map("notif_type")
}

enum NotificationPriority {
  low
  medium
  high
  urgent

  @@map("notif_priority")
}

enum ResponsibilityPriority {
  low
  medium
  high

  @@map("responsibility_priority")
}

enum DateFormat {
  DD_MM_YYYY @map("DD/MM/YYYY")
  MM_DD_YYYY @map("MM/DD/YYYY")
  YYYY_MM_DD @map("YYYY-MM-DD")

  @@map("date_format_type")
}

enum FiscalYearMonth {
  January
  February
  March
  April
  May
  June
  July
  August
  September
  October
  November
  December

  @@map("fiscal_month_type")
}

enum Theme {
  light
  dark
  system

  @@map("theme_type")
}

// ============================================================
// DEPARTMENT
// ============================================================

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  headId      String?  @map("head_id") // deferred FK → staff.id
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff      Staff[]
  users      User[]
  committees Committee[]

  @@map("departments")
}

// ============================================================
// RANK
// ============================================================

model Rank {
  id          String   @id @default(uuid())
  title       String
  level       Int
  description String?
  // salaryGrade String?  @map("salary_grade")
  // category     String?                          // TEXT in SQL — not an enum
  // requirements String?
  // isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff Staff[]

  @@map("ranks")
}

// ============================================================
// STAFF
// ============================================================

model Staff {
  id                     String        @id @default(uuid())
  staffNo                String        @unique @map("staff_no")
  title                  String? // "Prof.", "Dr.", "Arc." etc.
  firstName              String        @map("first_name")
  lastName               String        @default("") @map("last_name")
  email                  String        @unique
  phone                  String?
  dateOfBirth            DateTime?     @map("date_of_birth") @db.Date
  gender                 Gender?
  address                String?
  city                   String?
  state                  String?
  lga                    String?
  departmentId           String?       @map("department_id") // nullable — some staff have no dept
  rankId                 String        @map("rank_id")
  rank                   String
  cadre                  Cadre
  staffCategory          StaffCategory @map("staff_category")
  maritalStatus          String?       @map("marital_status") // nullable in real data
  religion               String?
  profilePhoto           String?       @map("profile_photo")
  natureOfAppointment    String?       @map("nature_of_appointment")
  conuassContiss         String?       @map("conuass_contiss")
  dateOfFirstAppointment DateTime?     @map("date_of_first_appointment") @db.Date
  dateOfLastPromotion    DateTime?     @map("date_of_last_promotion") @db.Date
  status                 StaffStatus   @default(Employed)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  department        Department?           @relation(fields: [departmentId], references: [id])
  rankDetails       Rank                  @relation(fields: [rankId], references: [id])
  user              User?
  qualifications    Qualification[]
  employmentHistory EmploymentHistory[]
  documents         Document[]
  payrolls          Payroll[]
  leaveRequests     LeaveRequest[]
  attendance        Attendance[]
  responsibilities  StaffResponsibility[]
  announcements     Announcement[]

  @@map("staff")
}

// ============================================================
// USER
// ============================================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @default("") @map("last_name")
  role         UserRole  @default(staff)
  staffId      String?   @unique @map("staff_id")
  departmentId String?   @map("department_id")
  profilePhoto String?   @map("profile_photo")
  phoneNumber  String?   @map("phone_number")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  staff                   Staff?                   @relation(fields: [staffId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id])
  notifications           Notification[]
  notificationPreferences NotificationPreferences?
  passwordResets          PasswordReset[]
  processedPayrolls       Payroll[]                @relation("ProcessedByUser")
  systemPreferences       SystemPreferences[]

  @@map("users")
}

// ============================================================
// QUALIFICATION
// ============================================================

model Qualification {
  id          String   @id @default(uuid())
  staffId     String   @map("staff_id")
  degree      String
  institution String
  year        String?
  level       String?
  isHighest   Boolean  @default(false) @map("is_highest")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("qualifications")
}

// ============================================================
// EMPLOYMENT HISTORY
// ============================================================

model EmploymentHistory {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  position   String
  department String
  subject    String?
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date // "Present" or "MMM YYYY"
  isCurrent  Boolean  @default(false) @map("is_current")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("employment_history")
}

// ============================================================
// DOCUMENT
// ============================================================

model Document {
  id          String   @id @default(uuid())
  staffId     String   @map("staff_id")
  title       String
  category    String
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size") // raw bytes
  mimeType    String   @map("mime_type")
  uploadedBy  String   @map("uploaded_by") // plain TEXT — no FK to users in SQL
  isVerified  Boolean  @default(false) @map("is_verified")
  verifiedBy  String?  @map("verified_by") // plain TEXT — no FK to users in SQL
  description String?
  degree      String?
  institution String?
  year        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ============================================================
// PAYROLL
// ============================================================

model Payroll {
  id              String        @id @default(uuid())
  staffId         String        @map("staff_id")
  month           DateTime      @db.Date // first day of month e.g. 2025-12-01
  monthLabel      String?       @map("month_label") // "December 2025"
  basicSalary     Decimal       @map("basic_salary") @db.Decimal(15, 2)
  allowances      Json // Record<string, number>
  totalAllowances Decimal       @map("total_allowances") @db.Decimal(15, 2)
  grossSalary     Decimal       @map("gross_salary") @db.Decimal(15, 2)
  deductions      Json // Record<string, number>
  totalDeductions Decimal       @map("total_deductions") @db.Decimal(15, 2)
  netSalary       Decimal       @map("net_salary") @db.Decimal(15, 2)
  status          PayrollStatus @default(DRAFT)
  paymentDate     DateTime?     @map("payment_date") @db.Date
  processedBy     String?       @map("processed_by")
  processedAt     DateTime?     @map("processed_at")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  staff           Staff @relation(fields: [staffId], references: [id])
  processedByUser User? @relation("ProcessedByUser", fields: [processedBy], references: [id])

  @@unique([staffId, month])
  @@map("payrolls")
}

// ============================================================
// LEAVE TYPE
// ============================================================

model LeaveType {
  id              String   @id @default(uuid())
  name            String   @unique
  allowedDays     Int      @map("allowed_days")
  carryForward    Boolean  @default(false) @map("carry_forward")
  maxCarryForward Int      @default(0) @map("max_carry_forward")
  paidLeave       Boolean  @default(true) @map("paid_leave")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  leaveRequests LeaveRequest[]

  @@map("leave_types")
}

// ============================================================
// LEAVE REQUEST
// ============================================================

model LeaveRequest {
  id               String      @id @default(uuid())
  staffId          String      @map("staff_id")
  leaveTypeId      String      @map("leave_type_id")
  startDate        DateTime    @map("start_date") @db.Date
  endDate          DateTime    @map("end_date") @db.Date
  totalDays        Int         @map("total_days")
  reason           String?
  status           LeaveStatus @default(PENDING)
  approverId       String?     @map("approver_id")
  approverComments String?     @map("approver_comments")
  appliedAt        DateTime    @default(now()) @map("applied_at")
  respondedAt      DateTime?   @map("responded_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  staff     Staff     @relation(fields: [staffId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@map("leave_requests")
}

// ============================================================
// ATTENDANCE
// ============================================================

model Attendance {
  id        String           @id @default(uuid())
  staffId   String           @map("staff_id")
  date      DateTime         @db.Date
  rate      String? // added via ALTER TABLE
  checkIn   DateTime?        @map("check_in")
  checkOut  DateTime?        @map("check_out")
  workHours Decimal?         @map("work_hours") @db.Decimal(4, 2)
  status    AttendanceStatus
  remarks   String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@map("attendance")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  type      NotificationType
  title     String
  message   String
  priority  NotificationPriority @default(low)
  read      Boolean              @default(false)
  icon      String?
  actionUrl String?              @map("action_url")
  metadata  Json                 @default("{}") // JSONB NOT NULL DEFAULT '{}'
  createdAt DateTime             @default(now()) @map("created_at")
  readAt    DateTime?            @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================
// NOTIFICATION PREFERENCES
// ============================================================

model NotificationPreferences {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  pushNotifications  Boolean  @default(true) @map("push_notifications")
  typeLeaveApproved  Boolean  @default(true) @map("type_leave_approved")
  typeLeaveRejected  Boolean  @default(true) @map("type_leave_rejected")
  typeLeavePending   Boolean  @default(true) @map("type_leave_pending")
  typePayroll        Boolean  @default(true) @map("type_payroll")
  typeContract       Boolean  @default(true) @map("type_contract")
  typeSystem         Boolean  @default(true) @map("type_system")
  typeProfile        Boolean  @default(true) @map("type_profile")
  typeAttendance     Boolean  @default(true) @map("type_attendance")
  typeGeneral        Boolean  @default(true) @map("type_general")
  quietHoursEnabled  Boolean  @default(false) @map("quiet_hours_enabled")
  quietHoursStart    String   @default("22:00") @map("quiet_hours_start")
  quietHoursEnd      String   @default("07:00") @map("quiet_hours_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============================================================
// PASSWORD RESET
// ============================================================

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ============================================================
// ANNOUNCEMENT
// ============================================================

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String
  priority    String    @default("normal")
  publishedBy String?   @map("published_by") // REFERENCES staff(id) nullable
  publishedAt DateTime  @default(now()) @map("published_at")
  expiresAt   DateTime? @map("expires_at") // nullable in SQL
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  publisher Staff? @relation(fields: [publishedBy], references: [id])

  @@map("announcements")
}

// ============================================================
// COMMITTEE
// ============================================================

model Committee {
  id              String   @id @default(uuid())
  name            String
  chairman        String?
  purpose         String?
  description     String?
  meetingSchedule String?  @map("meeting_schedule")
  isActive        Boolean  @default(true) @map("is_active")
  departmentId    String?  @map("department_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department Department?       @relation(fields: [departmentId], references: [id])
  members    CommitteeMember[]

  @@map("committees")
}

model CommitteeMember {
  id          String   @id @default(uuid())
  committeeId String   @map("committee_id")
  staffId     String   @map("staff_id") // plain TEXT — no FK to staff in SQL
  createdAt   DateTime @default(now()) @map("created_at")

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@unique([committeeId, staffId])
  @@map("committee_members")
}

// ============================================================
// NATURE OF APPOINTMENT
// ============================================================

model NatureOfAppointment {
  id          String   @id @default(uuid())
  name        String   @unique
  duration    String?
  benefits    String[]
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("nature_of_appointments")
}

// ============================================================
// RESPONSIBILITY
// ============================================================

model Responsibility {
  id          String                 @id @default(uuid())
  title       String
  description String
  department  String?
  isActive    Boolean                @default(true) @map("is_active")
  priority    ResponsibilityPriority @default(low)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  assignedTo StaffResponsibility[]

  @@map("responsibilities")
}

model StaffResponsibility {
  staffId          String   @map("staff_id")
  responsibilityId String   @map("responsibility_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")

  staff          Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  responsibility Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  @@id([staffId, responsibilityId])
  @@map("staff_responsibilities")
}

// ============================================================
// SYSTEM PREFERENCES  (singleton — one row)
// ============================================================

model SystemPreferences {
  id                      String          @id @default(uuid())
  institutionName         String          @map("institution_name")
  institutionAbbreviation String          @map("institution_abbreviation")
  dateFormat              DateFormat      @default(DD_MM_YYYY) @map("date_format")
  fiscalYearStart         FiscalYearMonth @default(January) @map("fiscal_year_start")
  leaveApprovalLevels     Int             @default(1) @map("leave_approval_levels")
  emailNotifications      Boolean         @default(true) @map("email_notifications")
  smsNotifications        Boolean         @default(false) @map("sms_notifications")
  theme                   Theme           @default(system)
  language                String          @default("en")
  timezone                String          @default("UTC")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  updatedBy               String?         @map("updated_by") // REFERENCES users(id)

  updatedByUser User? @relation(fields: [updatedBy], references: [id])

  @@map("system_preferences")
}
